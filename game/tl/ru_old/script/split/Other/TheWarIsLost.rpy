translate ru TheWarIsLost_c12e9f7e:
    # "Tears began to run down Sarah's cheeks."
    ""

translate ru TheWarIsLost_99cc4f96:
    # "She wanted to stop herself from crying, but hardly could, her shoulders shook from her sobbing."
