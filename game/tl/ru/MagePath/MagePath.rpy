# -*- encoding: utf-8 -*-
# Arc: MagePath | Scene: MagePath
# Source: C:\Program Files (x86)\Steam\steamapps\common\The Survival of Sarah Rose\game\script.rpy

translate ru strings:

    old "Sarah feels the man's hand snatch her across the mouth, clamping it shut."
    new "Sarah feels the man's hand snatch her across the mouth, clamping it shut."

    old "Brigand\" \"You stupid whore!"
    new "Brigand\" \"You stupid whore!"

    old "Brigand\" \"The city guard barely patrols this part of town."
    new "Brigand\" \"The city guard barely patrols this part of town."

    old "Brigand\" \"Nobody is gonna save you."
    new "Brigand\" \"Nobody is gonna save you."

    old "Brigand\" \"I was gonna be nice to you, but now I think I'll just rape you up against this wall, slit your throat and leave your body for the rats to find."
    new "Brigand\" \"I was gonna be nice to you, but now I think I'll just rape you up against this wall, slit your throat and leave your body for the rats to find."

    old "Sarah feels herself spun around and violently pushed up against the wall."
    new "Sarah feels herself spun around and violently pushed up against the wall."

    old "The force is so great, the air is pushed out of her lungs."
    new "The force is so great, the air is pushed out of her lungs."

    old "Behind her, she feels the man fumbling at her dress."
    new "Behind her, she feels the man fumbling at her dress."

    old "She prays in her mind."
    new "She prays in her mind."

    old "Don't let this happen to me."
    new "Don't let this happen to me."

    old "A voice rings out from across the street."
    new "A voice rings out from across the street."

    old "What is going on here?"
    new "What is going on here?"

    old "Brigand\" \"None of your business. Get lost if you know what's good for you."
    new "Brigand\" \"None of your business. Get lost if you know what's good for you."

    old "The man keeps Sarah pinned against the wall."
    new "The man keeps Sarah pinned against the wall."

    old "I wasn't asking you, I was asking the lady."
    new "I wasn't asking you, I was asking the lady."

    old "Sarah reaches deep within herself, summoning all her power, and calls out to him."
    new "Sarah reaches deep within herself, summoning all her power, and calls out to him."

    old "Help me! He's attacking me!"
    new "Help me! He's attacking me!"

    old "Sarah feels the man's fist driving into her side, she loses her breath again."
    new "Sarah feels the man's fist driving into her side, she loses her breath again."

    old "Let go of her."
    new "Let go of her."

    old "Brigand\" \"Get lost, or I'll knife you too!"
    new "Brigand\" \"Get lost, or I'll knife you too!"

    old "Suddenly, a bright light cuts through the darkness."
    new "Suddenly, a bright light cuts through the darkness."

    old "The same voice calls out, but this time, it roars like thunder. Sarah imagines she can even feel the cobblestones shake."
    new "The same voice calls out, but this time, it roars like thunder. Sarah imagines she can even feel the cobblestones shake."

    old "I won't warn you again, let go of her."
    new "I won't warn you again, let go of her."

    old "Brigand\" \"You...you're a...fuck this..."
    new "Brigand\" \"You...you're a...fuck this..."

    old "Sarah feels the man's entire pressure dissapear and hears metal clattering as his dagger falls to the ground."
    new "Sarah feels the man's entire pressure dissapear and hears metal clattering as his dagger falls to the ground."

    old "Before she manages to turn around, the brigand is already far away. She can only hear the echoes of his footsteps."
    new "Before she manages to turn around, the brigand is already far away. She can only hear the echoes of his footsteps."

    old "Only the man who saved her is left in the alley."
    new "Only the man who saved her is left in the alley."

    old "The source of light is now gone."
    new "The source of light is now gone."

    old "Sarah tries to answer him, but as her heart still races, she can't produce the words."
    new "Sarah tries to answer him, but as her heart still races, she can't produce the words."

    old "She begins to sob."
    new "She begins to sob."

    old "Did he hurt you?"
    new "Did he hurt you?"

    old "He had, but thanks to this man, nothing more than what she could sleep off. Phyiscally, anyway."
    new "He had, but thanks to this man, nothing more than what she could sleep off. Phyiscally, anyway."

    old "Thank god that you screamed, I got here just in time."
    new "Thank god that you screamed, I got here just in time."

    old "What were you doing out here alone? Even I don't like to walk the streets of Lethram at night."
    new "What were you doing out here alone? Even I don't like to walk the streets of Lethram at night."

    old "Sarah slowly calms down and is able to answer the man again."
    new "Sarah slowly calms down and is able to answer the man again."

    old "She looks up at him for the first time."
    new "She looks up at him for the first time."

    old "He's tall. Older than her, but only forty or so, she estimates."
    new "He's tall. Older than her, but only forty or so, she estimates."

    old "Balanced on the edge of his nose is a pair of glasses."
    new "Balanced on the edge of his nose is a pair of glasses."

    old "He wears an odd set of robes that Sarah has never seen before in her life. Something like a priest, she wonders, but no priest she'd ever seen."
    new "He wears an odd set of robes that Sarah has never seen before in her life. Something like a priest, she wonders, but no priest she'd ever seen."

    old "Kind. Above all, kind eyes and an easy smile."
    new "Kind. Above all, kind eyes and an easy smile."

    old "She wondered for a moment if you could tell a person's nature from just their eyes. She hoped that for this man, that was the case."
    new "She wondered for a moment if you could tell a person's nature from just their eyes. She hoped that for this man, that was the case."

    old "I was...I was trying to sleep here, in the alley, but he threatend me, and he tried to attack me. He said it was his alley, I didn't know..."
    new "I was...I was trying to sleep here, in the alley, but he threatend me, and he tried to attack me. He said it was his alley, I didn't know..."

    old "Not his alley, no, just a violent creep that stalks the streets. This city is full of them, sadly."
    new "Not his alley, no, just a violent creep that stalks the streets. This city is full of them, sadly."

    old "How do you know?"
    new "How do you know?"

    old "Because this is my alley, actually. This right here is my house."
    new "Because this is my alley, actually. This right here is my house."

    old "The man slapped the sides of the wall that Sarah had been sleeping against."
    new "The man slapped the sides of the wall that Sarah had been sleeping against."

    old "I was still up, studying, when suddenly I heard your scream. I rushed outside and I found you."
    new "I was still up, studying, when suddenly I heard your scream. I rushed outside and I found you."

    old "Thank you for saving me. Really, I don't want to think about what he would have done to me."
    new "Thank you for saving me. Really, I don't want to think about what he would have done to me."

    old "I wouldn't forgive myself if I hadn't."
    new "I wouldn't forgive myself if I hadn't."

    old "Anyway, did I hear you correctly? You said you were sleeping out here?"
    new "Anyway, did I hear you correctly? You said you were sleeping out here?"

    old "The man eyed her clothes."
    new "The man eyed her clothes."

    old "You don't strike me as very poor..."
    new "You don't strike me as very poor..."

    old "You really don't have a place you can stay?"
    new "You really don't have a place you can stay?"

    old "It's a long story, but no, I don't have anywhere to go."
    new "It's a long story, but no, I don't have anywhere to go."

    old "If you would let me sleep here, I would be forever grateful."
    new "If you would let me sleep here, I would be forever grateful."

    old "The man shook his head again."
    new "The man shook his head again."

    old "Don't be ridiculous."
    new "Don't be ridiculous."

    old "I'm not going to let you sleep out here on the street."
    new "I'm not going to let you sleep out here on the street."

    old "This city is so full of criminals, another one would come across you in no time."
    new "This city is so full of criminals, another one would come across you in no time."

    old "Come, follow me."
    new "Come, follow me."

    old "The man walked out of the alley. Sarah followed him. It seemed to make sense."
    new "The man walked out of the alley. Sarah followed him. It seemed to make sense."

    old "As soon as they were back on the street, the man turned around to the first house off the alley, and opened the door, leading her inside."
    new "As soon as they were back on the street, the man turned around to the first house off the alley, and opened the door, leading her inside."

    old "The inside of the house was vast, far larger than the modest outside would have suggested."
    new "The inside of the house was vast, far larger than the modest outside would have suggested."

    old "A small oil lamp was situated on a table, covered in books, randomly strewn across one another, some open, some closed."
    new "A small oil lamp was situated on a table, covered in books, randomly strewn across one another, some open, some closed."

    old "The man closed the door behind Sarah."
    new "The man closed the door behind Sarah."

    old "I've got more space than I need, so you're free to spend the night here."
    new "I've got more space than I need, so you're free to spend the night here."

    old "You're being so kind..."
    new "You're being so kind..."

    old "The man waved his hands, dismissing her comment."
    new "The man waved his hands, dismissing her comment."

    old "Don't worry about it. I know what it's like to not have a lot. If I can give back a little, I'm always happy to."
    new "Don't worry about it. I know what it's like to not have a lot. If I can give back a little, I'm always happy to."

    old "Suddenly, the man seemed to catch himself."
    new "Suddenly, the man seemed to catch himself."

    old "Ooh, where are my manners."
    new "Ooh, where are my manners."

    old "I haven't even introduced myself."
    new "I haven't even introduced myself."

    old "He stuck out his hand to her."
    new "He stuck out his hand to her."

    old "My name is Xanthippe, but you can call me Xan. Most everyone does."
    new "My name is Xanthippe, but you can call me Xan. Most everyone does."

    old "Sarah took his hand and shook it. So large were his that they all but enveloped hers."
    new "Sarah took his hand and shook it. So large were his that they all but enveloped hers."

    old "Xant...Xanthiff...Xanthir..."
    new "Xant...Xanthiff...Xanthir..."

    old "The man laughed at her struggling to pronounce his name."
    new "The man laughed at her struggling to pronounce his name."

    old "Like I said, just call me Xan, nobody ever manages to pronounce it."
    new "Like I said, just call me Xan, nobody ever manages to pronounce it."

    old "Ok, thank you Xan. Not just for saving me, but also letting me stay here. I wouldn't have known what to do. I don't have anywhere else to go."
    new "Ok, thank you Xan. Not just for saving me, but also letting me stay here. I wouldn't have known what to do. I don't have anywhere else to go."

    old "Xan sat down in his chair and looked at her."
    new "Xan sat down in his chair and looked at her."

    old "Yeah...about that."
    new "Yeah...about that."

    old "I've come across all sorts of people, in all sorts of trouble, but you..."
    new "I've come across all sorts of people, in all sorts of trouble, but you..."

    old "You're dressed like royalty, but you're sleeping out in the streets? That's a new one for me."
    new "You're dressed like royalty, but you're sleeping out in the streets? That's a new one for me."

    old "Sarah sat down in the other chair opposite of him."
    new "Sarah sat down in the other chair opposite of him."

    old "She didn't know if it was the exhaustion, or her close encounter with death, but right now, she just wanted someone to see her."
    new "She didn't know if it was the exhaustion, or her close encounter with death, but right now, she just wanted someone to see her."

    old "Someone to know who she was."
    new "Someone to know who she was."

    old "I'll tell you. Everything."
    new "I'll tell you. Everything."

    old "Deep into the night, Sarah told her story, everything from having lived in Rosanna to what had brought her to Lethram and caused her to end up on his doorstep."
    new "Deep into the night, Sarah told her story, everything from having lived in Rosanna to what had brought her to Lethram and caused her to end up on his doorstep."

    old "Xan, for his part, seemed to be both deeply interested in her story, as well as strangely without judgement."
    new "Xan, for his part, seemed to be both deeply interested in her story, as well as strangely without judgement."

    old "He never questioned her decisions, scolded her, or tried to give advice."
    new "He never questioned her decisions, scolded her, or tried to give advice."

    old "He only listened, and asked the occasional question, probing for more information when something was unclear."
    new "He only listened, and asked the occasional question, probing for more information when something was unclear."

    old "By the end of the night, he knew her, and Sarah was glad to be known."
    new "By the end of the night, he knew her, and Sarah was glad to be known."

    old "It's quite the story, Sarah."
    new "It's quite the story, Sarah."

    old "But I'm happy it didn't end in tragedy."
    new "But I'm happy it didn't end in tragedy."

    old "You really shouldn't be sleeping out on the streets though. Certainly not in Lethram, it's too dangerous."
    new "You really shouldn't be sleeping out on the streets though. Certainly not in Lethram, it's too dangerous."

    old "I promise, I won't do it again."
    new "I promise, I won't do it again."

    old "You can stay here for as long as you like."
    new "You can stay here for as long as you like."

    old "Sarah turned her head away, staring at the floor."
    new "Sarah turned her head away, staring at the floor."

    old "Why was this man being so kind to her? In a city where everyone seemed to be after something, could he really just be offering this out of kindness?"
    new "Why was this man being so kind to her? In a city where everyone seemed to be after something, could he really just be offering this out of kindness?"

    old "Was she lucky, or being tricked?"
    new "Was she lucky, or being tricked?"

    old "I wouldn't want to impose."
    new "I wouldn't want to impose."

    old "Not at all. If you feel like you want to earn your keep, you can do some cleaning around the house."
    new "Not at all. If you feel like you want to earn your keep, you can do some cleaning around the house."

    old "Honestly, it's far too large for me, and I don't even use all the rooms. It's a hassle just to keep it from falling apart on me."
    new "Honestly, it's far too large for me, and I don't even use all the rooms. It's a hassle just to keep it from falling apart on me."

    old "Sarah nodded excitedly."
    new "Sarah nodded excitedly."

    old "It wasn't so much cleaning the house, as feeling that she could make herself useful again."
    new "It wasn't so much cleaning the house, as feeling that she could make herself useful again."

    old "She had been following and rushing from one point to the next for so long, that a chance to just sit and be useful seemed all she could want."
    new "She had been following and rushing from one point to the next for so long, that a chance to just sit and be useful seemed all she could want."

    old "Thank you, and I will."
    new "Thank you, and I will."

    old "Sarah stood up from her chair."
    new "Sarah stood up from her chair."

    old "Anyway, if you'll excuse me, I'm very tired. I'm going to try to get some sleep."
    new "Anyway, if you'll excuse me, I'm very tired. I'm going to try to get some sleep."

    old "Xan nodded."
    new "Xan nodded."

    old "Of course, just use any of the empty rooms. I'll be in here for a bit more, studying, in case you need anything."
    new "Of course, just use any of the empty rooms. I'll be in here for a bit more, studying, in case you need anything."

    old "Sarah waved as she left, but found that Xan had already turned back towards his books."
    new "Sarah waved as she left, but found that Xan had already turned back towards his books."

    old "Down the hallway, she found one of several rooms, each in a condition as if they'd never even been lived in since the house was sold. Untouched."
    new "Down the hallway, she found one of several rooms, each in a condition as if they'd never even been lived in since the house was sold. Untouched."

    old "Choosing one at random, she set down her things and fell into the bed."
    new "Choosing one at random, she set down her things and fell into the bed."

    old "It wasn't anything special, but in that moment, it was one of the best sleeps she ever had."
    new "It wasn't anything special, but in that moment, it was one of the best sleeps she ever had."

