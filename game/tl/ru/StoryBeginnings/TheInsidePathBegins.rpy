# -*- encoding: utf-8 -*-
# Arc: StoryBeginnings | Scene: TheInsidePathBegins
# Source: C:\Program Files (x86)\Steam\steamapps\common\The Survival of Sarah Rose\game\script.rpy

translate ru strings:

    old "Sarah, instinctively, pulls herself physically away from Kate."
    new "Sarah, instinctively, pulls herself physically away from Kate."

    old "She looks at her old friend. Her brown eyes seem almost black in the dark. Within them, she sees something break."
    new "She looks at her old friend. Her brown eyes seem almost black in the dark. Within them, she sees something break."

    old "Sarah...please..."
    new "Sarah...please..."

    old "Sarah shakes her head."
    new "Sarah shakes her head."

    old "It doesn't matter if I'm in danger here, Kate. Thomas needs me, he always did, but now more than ever."
    new "It doesn't matter if I'm in danger here, Kate. Thomas needs me, he always did, but now more than ever."

    old "If you think that I'm going to leave him alone...then you don't really know me at all."
    new "If you think that I'm going to leave him alone...then you don't really know me at all."

    old "I will stay here, even if it means risking my life."
    new "I will stay here, even if it means risking my life."

    old "Kate climbs off the bed."
    new "Kate climbs off the bed."

    old "Then you're an idiot. You don't know anything about the dangers of this world."
    new "Then you're an idiot. You don't know anything about the dangers of this world."

    old "There will be a day when you wish you took my hand, and when that day comes, remember that I offered, and it was you who declined."
    new "There will be a day when you wish you took my hand, and when that day comes, remember that I offered, and it was you who declined."

    old "Sarah steels herself and looks at Kate."
    new "Sarah steels herself and looks at Kate."

    old "I've said my part. Get out before I have you dragged out by the guards."
    new "I've said my part. Get out before I have you dragged out by the guards."

    old "Kate shakes her head in disbelief. She pauses for a moment, trying to find the words, but finds none."
    new "Kate shakes her head in disbelief. She pauses for a moment, trying to find the words, but finds none."

    old "Kate turns and walks towards the door in large strides."
    new "Kate turns and walks towards the door in large strides."

    old "As she opens the door, she stands in the opening and turns around, looking at Sarah one last time."
    new "As she opens the door, she stands in the opening and turns around, looking at Sarah one last time."

    old "Sarah sees that, again, Kate has no words."
    new "Sarah sees that, again, Kate has no words."

    old "Kate slips out the door, closing it softly, and vanishes."
    new "Kate slips out the door, closing it softly, and vanishes."

    old "Sarah tries to get back to sleep, but her thoughts keep her awake."
    new "Sarah tries to get back to sleep, but her thoughts keep her awake."

    old "She wonders if she will ever see her old friend again."
    new "She wonders if she will ever see her old friend again."

    old "Eventually, exhaustion carries Sarah off to sleep."
    new "Eventually, exhaustion carries Sarah off to sleep."

