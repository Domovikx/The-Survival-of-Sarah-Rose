# -*- encoding: utf-8 -*-
# Arc: PrisonArc | Scene: UnderworldPath4
# Source: C:\Program Files (x86)\Steam\steamapps\common\The Survival of Sarah Rose\game\script.rpy

translate ru strings:

    old "Turning around, she saw that he was already gone."
    new "Turning around, she saw that he was already gone."

    old "She considered turning back over and getting some more rest, but a sound near the end of the alley drew her attention."
    new "She considered turning back over and getting some more rest, but a sound near the end of the alley drew her attention."

    old "Something made out of wood, like a crate, clattered hard against the cobblestone."
    new "Something made out of wood, like a crate, clattered hard against the cobblestone."

    old "A city like Lethram was always filled with various noises, but Sarah had learned by now that people rarely came to this particular alley."
    new "A city like Lethram was always filled with various noises, but Sarah had learned by now that people rarely came to this particular alley."

    old "Voices."
    new "Voices."

    old "She couldn't make out what they were saying, but it was the tone that made her heart skip."
    new "She couldn't make out what they were saying, but it was the tone that made her heart skip."

    old "Sarah knew how soldiers and guards sounded, their authoritative tone."
    new "Sarah knew how soldiers and guards sounded, their authoritative tone."

    old "Run"
    new "Run"

    old "Hide"
    new "Hide"

    old "There was nowhere to go. If she made a run for it, they'd surely catch her."
    new "There was nowhere to go. If she made a run for it, they'd surely catch her."

    old "Sarah laid back down in the bed and pulled the covers over herself."
    new "Sarah laid back down in the bed and pulled the covers over herself."

    old "As she laid, trembling, she heard the sounds of the footsteps drawing closer."
    new "As she laid, trembling, she heard the sounds of the footsteps drawing closer."

    old "Their heavy, coarse voices."
    new "Their heavy, coarse voices."

    old "Guard Captain\" \"They're here somewhere!"
    new "Guard Captain\" \"They're here somewhere!"

    old "Guard Captain\" \"Tear up everything if you have to!"
    new "Guard Captain\" \"Tear up everything if you have to!"

    old "Sarah heard men begin to smash crates."
    new "Sarah heard men begin to smash crates."

    old "The violent sounds grew louder and louder as they came nearer."
    new "The violent sounds grew louder and louder as they came nearer."

    old "Guard\" \"Sir!"
    new "Guard\" \"Sir!"

    old "Sarah could hear his voice so close, as if he was right next to her."
    new "Sarah could hear his voice so close, as if he was right next to her."

    old "She felt her heart pounding in her chest."
    new "She felt her heart pounding in her chest."

    old "This had been a mistake."
    new "This had been a mistake."

    old "Guard\" \"There's a tent here!"
    new "Guard\" \"There's a tent here!"

    old "The sounds of more plated boots, drawing closer."
    new "The sounds of more plated boots, drawing closer."

    old "Sarah pulled the cover over herself as if it might offer some protection."
    new "Sarah pulled the cover over herself as if it might offer some protection."

    old "A brief few seconds more, before they'd catch her."
    new "A brief few seconds more, before they'd catch her."

    old "Guard Captain\" \"Good work. Rip this apart!"
    new "Guard Captain\" \"Good work. Rip this apart!"

    old "Sarah heard them tearing away the thin fabric that made up her tent. What now passed for a home."
    new "Sarah heard them tearing away the thin fabric that made up her tent. What now passed for a home."

    old "She remained still, trembling under the covers."
    new "She remained still, trembling under the covers."

    old "Guard Captain\" \"Girl, the game is up."
    new "Guard Captain\" \"Girl, the game is up."

    old "Guard Captain\" \"Crawl out from under there before I make my men drag you out."
    new "Guard Captain\" \"Crawl out from under there before I make my men drag you out."

    old "Sarah slowly pulled the covers away."
    new "Sarah slowly pulled the covers away."

    old "Sir..."
    new "Sir..."

    old "I didn't do anything, I was just sleeping here, I swear that I-"
    new "I didn't do anything, I was just sleeping here, I swear that I-"

    old "Guard Captain\" \"Spare me the excuses, rat."
    new "Guard Captain\" \"Spare me the excuses, rat."

    old "He snapped his fingers."
    new "He snapped his fingers."

    old "Guard Captain\" \"Grab her! And put the irons on her, I don't want her running away."
    new "Guard Captain\" \"Grab her! And put the irons on her, I don't want her running away."

    old "The guards loomed large in front of her."
    new "The guards loomed large in front of her."

    old "Sarah tried to move, but she was too slow."
    new "Sarah tried to move, but she was too slow."

    old "She could feel their grips close around her wrist, holding her down."
    new "She could feel their grips close around her wrist, holding her down."

    old "Hands, covered in armor, closed around her mouth."
    new "Hands, covered in armor, closed around her mouth."

    old "She tried to scream, but it was no use."
    new "She tried to scream, but it was no use."

    old "For a moment, she twisted and wrung her body, hoping to break free, but then they pulled and twisted her arm, pinning it on her back."
    new "For a moment, she twisted and wrung her body, hoping to break free, but then they pulled and twisted her arm, pinning it on her back."

    old "With unstoppable force, Sarah felt herself pinned up against the ground."
    new "With unstoppable force, Sarah felt herself pinned up against the ground."

    old "Guard\" \"Struggle some more and I'll break you arm, rat!"
    new "Guard\" \"Struggle some more and I'll break you arm, rat!"

    old "She could feel the breath escape her lungs as he pushed her harder up against the wall."
    new "She could feel the breath escape her lungs as he pushed her harder up against the wall."

    old "Guard\" \"They're gonna hang you for this, thief."
    new "Guard\" \"They're gonna hang you for this, thief."

    old "Sarah wanted to scream. Cry. Beg."
    new "Sarah wanted to scream. Cry. Beg."

    old "But she could do none of it."
    new "But she could do none of it."

    old "She prayed Alaric would save her again, but this time, he was nowhere to be found."
    new "She prayed Alaric would save her again, but this time, he was nowhere to be found."

    old "She heard the sounds of metal boots stomping against the ground."
    new "She heard the sounds of metal boots stomping against the ground."

    old "Around the corner, more and more guards rushed in."
    new "Around the corner, more and more guards rushed in."

    old "From the corner of her eyes, Sarah could spot them. Too many to count."
    new "From the corner of her eyes, Sarah could spot them. Too many to count."

    old "Even if Alaric came for her now, he'd just be cut down."
    new "Even if Alaric came for her now, he'd just be cut down."

    old "It was over."
    new "It was over."

    old "Sarah felt a hood pulled over her head."
    new "Sarah felt a hood pulled over her head."

    old "Ropes slipped through her wrists, binding her arms, then her legs."
    new "Ropes slipped through her wrists, binding her arms, then her legs."

    old "Before long, she couldn't move. See. Even the sound around her were muted."
    new "Before long, she couldn't move. See. Even the sound around her were muted."

    old "The only thing she could hear were their taunts and threats."
    new "The only thing she could hear were their taunts and threats."

    old "She could feel more hands close around her body as they began to move her."
    new "She could feel more hands close around her body as they began to move her."

    old "Sarah had no way to fight them, all she could do was let herself be taken by them."
    new "Sarah had no way to fight them, all she could do was let herself be taken by them."

    old "They kept the hood over her head for long enough that Sarah began to doubt what time it was."
    new "They kept the hood over her head for long enough that Sarah began to doubt what time it was."

    old "Hours? She wasn't sure."
    new "Hours? She wasn't sure."

    old "They had sat her down somewhere, but nobody told her anything. There was only the darkness."
    new "They had sat her down somewhere, but nobody told her anything. There was only the darkness."

    old "After hours more, finally, the hood was pulled off."
    new "After hours more, finally, the hood was pulled off."

    old "For a moment, Sarah tried to process."
    new "For a moment, Sarah tried to process."

    old "Not only was it the sudden light, but also the room itself. She'd never been here before. It all seemed so alien to her."
    new "Not only was it the sudden light, but also the room itself. She'd never been here before. It all seemed so alien to her."

    old "A man sat opposite of her. The man that had removed the hood."
    new "A man sat opposite of her. The man that had removed the hood."

    old "His attitude and the adornments on his armor told her he was important."
    new "His attitude and the adornments on his armor told her he was important."

    old "Guard Captain\" \"You're in a lot of trouble."
    new "Guard Captain\" \"You're in a lot of trouble."

    old "Sir!"
    new "Sir!"

    old "I...I don't know what this is about, but I promise you, this is a mistake!"
    new "I...I don't know what this is about, but I promise you, this is a mistake!"

    old "The man reached out and slapped her across the face."
    new "The man reached out and slapped her across the face."

    old "Sarah felt her face begin to burn."
    new "Sarah felt her face begin to burn."

    old "More than the pain of the slap was the surprise of it. Guards...these were honorable people, Sarah thought. How could they do this?"
    new "More than the pain of the slap was the surprise of it. Guards...these were honorable people, Sarah thought. How could they do this?"

    old "Guard Captain\" \"Let me make something very clear to you."
    new "Guard Captain\" \"Let me make something very clear to you."

    old "Guard Captain\" \"I keep the order in this part of town. I keep that order in whatever way I see fit."
    new "Guard Captain\" \"I keep the order in this part of town. I keep that order in whatever way I see fit."

    old "Guard Captain\" \"I act under direct authority of the city council."
    new "Guard Captain\" \"I act under direct authority of the city council."

    old "Guard Captain\" \"Thievin rats like you and your buddy disrupt that order for all the good citizens of Lethram. The law-abiding citizens."
    new "Guard Captain\" \"Thievin rats like you and your buddy disrupt that order for all the good citizens of Lethram. The law-abiding citizens."

    old "Guard Captain\" \"So, when I-"
    new "Guard Captain\" \"So, when I-"

    old "Please, captain, I-"
    new "Please, captain, I-"

    old "Another smack followed, this one even more harsh than the last."
    new "Another smack followed, this one even more harsh than the last."

    old "Guard Captain\" \"You speak when spoken to. Do you understand that?!"
    new "Guard Captain\" \"You speak when spoken to. Do you understand that?!"

    old "His voice roared through the small room."
    new "His voice roared through the small room."

    old "Sarah struggled to suppres her instinct to cry, forcing herself to be calm."
    new "Sarah struggled to suppres her instinct to cry, forcing herself to be calm."

    old "Yes...sir..."
    new "Yes...sir..."

    old "Guard Captain\" \"Good."
    new "Guard Captain\" \"Good."

    old "Guard Captain\" \"Now, as I was saying, when I vow to do everything to protect the order in this city, I mean that."
    new "Guard Captain\" \"Now, as I was saying, when I vow to do everything to protect the order in this city, I mean that."

    old "The man cleared his throat and began to read from a sheet of paper."
    new "The man cleared his throat and began to read from a sheet of paper."

    old "Guard Captain\" \"You and your co-conspirator match a description for two criminals seen operating at a nearby market."
    new "Guard Captain\" \"You and your co-conspirator match a description for two criminals seen operating at a nearby market."

    old "Guard Captain\" \"The witness is reliable enough, but I want to wrap this case up nice and tidy."
    new "Guard Captain\" \"The witness is reliable enough, but I want to wrap this case up nice and tidy."

    old "The man leaned in."
    new "The man leaned in."

    old "Guard Captain\" \"So listen her, girly, I know you ain't the one to blame."
    new "Guard Captain\" \"So listen her, girly, I know you ain't the one to blame."

    old "Guard Captain\" \"It was that fucking lowlife partner of yours. He got you all twisted and on the wrong path."
    new "Guard Captain\" \"It was that fucking lowlife partner of yours. He got you all twisted and on the wrong path."

    old "Guard Captain\" \"You look like a good girl, a decent person. You know stealin is wrong."
    new "Guard Captain\" \"You look like a good girl, a decent person. You know stealin is wrong."

    old "The man pointed over towards the wall."
    new "The man pointed over towards the wall."

    old "Guard Captain\" \"Can you believe that lowlife is sitting in the room next door, trying to pin this all on you?"
    new "Guard Captain\" \"Can you believe that lowlife is sitting in the room next door, trying to pin this all on you?"

    old "Guard Captain\" \"Said you corrupted him, seduced him to do this."
    new "Guard Captain\" \"Said you corrupted him, seduced him to do this."

    old "The man shook his head."
    new "The man shook his head."

    old "Guard Captain\" \"Disgusting what they'll say just to get out from a charge."
    new "Guard Captain\" \"Disgusting what they'll say just to get out from a charge."

    old "Guard Captain\" \"So tell you what. You confess and testify your friend in the room over was the one with the scheme, and I'll put in a good word for you."
    new "Guard Captain\" \"So tell you what. You confess and testify your friend in the room over was the one with the scheme, and I'll put in a good word for you."

    old "Guard Captain\" \"I can't promise no time, but maybe just a few weeks in a labour house."
    new "Guard Captain\" \"I can't promise no time, but maybe just a few weeks in a labour house."

    old "The man leaned back in his chair."
    new "The man leaned back in his chair."

    old "Guard Captain\" \"But tell you what girly, I also don't really give a fuck either which way."
    new "Guard Captain\" \"But tell you what girly, I also don't really give a fuck either which way."

    old "Guard Captain\" \"You say nothin, sure, we go with his testimony and we pin it all on you."
    new "Guard Captain\" \"You say nothin, sure, we go with his testimony and we pin it all on you."

    old "Sarah listend as the guard captain laid out her options."
    new "Sarah listend as the guard captain laid out her options."

    old "Testify against Alaric and she would be spared..."
    new "Testify against Alaric and she would be spared..."

    old "But what if he was lying? What if they didn't have anything and the captain was just bluffing?"
    new "But what if he was lying? What if they didn't have anything and the captain was just bluffing?"

    old "She might send Alaric to prison for no reason at all, just because she got scared."
    new "She might send Alaric to prison for no reason at all, just because she got scared."

    old "Guard Captain\" \"Well? You got an answer for me, girly?"
    new "Guard Captain\" \"Well? You got an answer for me, girly?"

    old "Testify against Alaric"
    new "Testify against Alaric"

    old "The thought of prison time, or worse, nearly made Sarah faint."
    new "The thought of prison time, or worse, nearly made Sarah faint."

    old "Whatever was the truth, she knew she was guilty. As was Alaric."
    new "Whatever was the truth, she knew she was guilty. As was Alaric."

    old "Her only chance to be spared was to throw herself on the guard captain's mercy."
    new "Her only chance to be spared was to throw herself on the guard captain's mercy."

    old "Refuse to answer his questions"
    new "Refuse to answer his questions"

    old "He was bluffing, Sarah was sure of it. He had nothing."
    new "He was bluffing, Sarah was sure of it. He had nothing."

