# -*- encoding: utf-8 -*-
# Arc: LifeInRahayal | Scene: LifeInRahayal3
# Source: C:\Program Files (x86)\Steam\steamapps\common\The Survival of Sarah Rose\game\script.rpy

translate ru strings:

    old "Sarah left and continued exploring the city."
    new "Sarah left and continued exploring the city."

    old "The setting sun had drowned the city in a golden light."
    new "The setting sun had drowned the city in a golden light."

    old "It wouldn't be long before it was night."
    new "It wouldn't be long before it was night."

    old "Though she didn't feel unsafe, she didn't want to risk getting lost in the city at night."
    new "Though she didn't feel unsafe, she didn't want to risk getting lost in the city at night."

    old "Sarah decided to give up on the day's search for a job and return back to the Inn."
    new "Sarah decided to give up on the day's search for a job and return back to the Inn."

    old "When she stepped through the door of the Inn, she was greeted by the same familiar atmosphere that always seemed to permeate the air."
    new "When she stepped through the door of the Inn, she was greeted by the same familiar atmosphere that always seemed to permeate the air."

    old "Sarah had only just sat down at the bar when Ramsey, the owner, walked up to her."
    new "Sarah had only just sat down at the bar when Ramsey, the owner, walked up to her."

    old "Hey there, you lookin aweful sad?"
    new "Hey there, you lookin aweful sad?"

    old "Sarah snapped out of her own thoughts."
    new "Sarah snapped out of her own thoughts."

    old "Oh...was I? I'm sorry..."
    new "Oh...was I? I'm sorry..."

    old "Ramsey just smiled."
    new "Ramsey just smiled."

    old "Ain't no worry, I just hope you ain't feelin as sad as you lookin."
    new "Ain't no worry, I just hope you ain't feelin as sad as you lookin."

    old "Sarah did her best to force a smile."
    new "Sarah did her best to force a smile."

    old "No, I'm fine, it's just..."
    new "No, I'm fine, it's just..."

    old "Ramsey tilted his head."
    new "Ramsey tilted his head."

    old "Nothing, I don't want to bother you with my troubles."
    new "Nothing, I don't want to bother you with my troubles."

    old "Listen, little lady, if you can't bother the barkeeper with your troubles, who can you bother with em?"
    new "Listen, little lady, if you can't bother the barkeeper with your troubles, who can you bother with em?"

    old "Sarah could't help but laugh."
    new "Sarah could't help but laugh."

    old "I mean...okay, if you really don't mind..."
    new "I mean...okay, if you really don't mind..."

    old "Sarah started telling him about her day. Slowly at first, then all at once."
    new "Sarah started telling him about her day. Slowly at first, then all at once."

    old "Walking the streets, searching for a job, turning it down, everything."
    new "Walking the streets, searching for a job, turning it down, everything."

    old "Ramsey listened attentively as she poke."
    new "Ramsey listened attentively as she poke."

    old "Only when she was finally done did he speak."
    new "Only when she was finally done did he speak."

    old "Well, that's quite a lot for a first day in town."
    new "Well, that's quite a lot for a first day in town."

    old "But if you ask me, I think it's a good thing."
    new "But if you ask me, I think it's a good thing."

    old "Yeah. Ain't hearin nothin but bad things about them Estates."
    new "Yeah. Ain't hearin nothin but bad things about them Estates."

    old "Rich folk. Powerful folk. Can't be trusted if you ask me. Better you be off chasin an honest job."
    new "Rich folk. Powerful folk. Can't be trusted if you ask me. Better you be off chasin an honest job."

    old "Thank you. It makes me feel a little better hearing that from you."
    new "Thank you. It makes me feel a little better hearing that from you."

    old "Ramsey smiled that broad smile of his."
    new "Ramsey smiled that broad smile of his."

    old "Like I said, that's what the barkeep is for, dumpin your troubles on."
    new "Like I said, that's what the barkeep is for, dumpin your troubles on."

    old "Thank you again for listening, it really helps."
    new "Thank you again for listening, it really helps."

    old "This place...it's still all so new. It can feel a little lonely."
    new "This place...it's still all so new. It can feel a little lonely."

    old "I know that's weird to say in a city with so many people."
    new "I know that's weird to say in a city with so many people."

    old "Ramsey nodded again."
    new "Ramsey nodded again."

    old "Makes sense to me. I see all types of folks, drifting through, lookin for a way to live."
    new "Makes sense to me. I see all types of folks, drifting through, lookin for a way to live."

    old "How do they find their way?"
    new "How do they find their way?"

    old "My advice?"
    new "My advice?"

    old "I think people need stuff to do."
    new "I think people need stuff to do."

    old "Ain't nothin worse for a person than idle hands and an idle head."
    new "Ain't nothin worse for a person than idle hands and an idle head."

    old "Sarah nodded along as he spoke."
    new "Sarah nodded along as he spoke."

    old "There was some truth to that, she figured."
    new "There was some truth to that, she figured."

    old "That's my problem, I guess. Still figuring that out."
    new "That's my problem, I guess. Still figuring that out."

    old "Ramsey leaned across the bar."
    new "Ramsey leaned across the bar."

    old "Ya know, you don't need to figure it all out in one day."
    new "Ya know, you don't need to figure it all out in one day."

    old "I means, you could take a job while you keep lookin for that real purpose you seem to be lookin for."
    new "I means, you could take a job while you keep lookin for that real purpose you seem to be lookin for."

    old "Sure...but where would I even start?"
    new "Sure...but where would I even start?"

    old "Again, that broad smile of his."
    new "Again, that broad smile of his."

    old "Why ain't you start here?"
    new "Why ain't you start here?"

    old "Sure."
    new "Sure."

    old "My kids are a great help, but as you can see, we got more customers than we can handle."
    new "My kids are a great help, but as you can see, we got more customers than we can handle."

    old "Sarah looked about and knew that it was true. The Inn always seemed full of people."
    new "Sarah looked about and knew that it was true. The Inn always seemed full of people."

    old "Sometimes I got customers waitin so long, they take off again."
    new "Sometimes I got customers waitin so long, they take off again."

    old "An extra pair of hands might just be what we need."
    new "An extra pair of hands might just be what we need."

    old "You're...offering me a job here? Working at the Inn?"
    new "You're...offering me a job here? Working at the Inn?"

    old "Wouldn't be no top job I'm afraid, but the pay is fair, and we can teach you on the job."
    new "Wouldn't be no top job I'm afraid, but the pay is fair, and we can teach you on the job."

    old "You could learn how to work the room from my daughter Elsa, and my son Jacob can teach you about the stocking room."
    new "You could learn how to work the room from my daughter Elsa, and my son Jacob can teach you about the stocking room."

    old "And tell you what, you do good work, you can keep the room you got here for free."
    new "And tell you what, you do good work, you can keep the room you got here for free."

    old "Sarah's eyes wide."
    new "Sarah's eyes wide."

    old "Ramsey made a good point. Even if she didn't want to keep working here forever, it would at least buy her time."
    new "Ramsey made a good point. Even if she didn't want to keep working here forever, it would at least buy her time."

    old "She'd keep a place over her head, make some extra coin...some space to breathe."
    new "She'd keep a place over her head, make some extra coin...some space to breathe."

    old "You...would really do that for me? We only just met..."
    new "You...would really do that for me? We only just met..."

    old "Ramsey smiled as he nodded."
    new "Ramsey smiled as he nodded."

    old "I got a good sense for people, and you strike me as an honest and hard worker."
    new "I got a good sense for people, and you strike me as an honest and hard worker."

    old "And customers appreciate a pretty lady helpin them out with their order."
    new "And customers appreciate a pretty lady helpin them out with their order."

    old "Sarah couldn't help but blush as the compliments."
    new "Sarah couldn't help but blush as the compliments."

    old "Tell you what, how bout you take the night to sleep it over?"
    new "Tell you what, how bout you take the night to sleep it over?"

    old "And if you're still interested, you can get started tomorrow, sound fair?"
    new "And if you're still interested, you can get started tomorrow, sound fair?"

    old "Thank you! I will!"
    new "Thank you! I will!"

    old "Ramsey looked past her."
    new "Ramsey looked past her."

    old "Gotta help out over there, but see you around!"
    new "Gotta help out over there, but see you around!"

    old "With that, he took off."
    new "With that, he took off."

    old "With the day winding down, Sarah decided to head to her room."
    new "With the day winding down, Sarah decided to head to her room."

    old "Sitting in the small yet quiet spot, she couldn't help but feel a little proud of herself."
    new "Sitting in the small yet quiet spot, she couldn't help but feel a little proud of herself."

    old "The day hadn't quite gone as she had planned, but she'd gotten a real job offer."
    new "The day hadn't quite gone as she had planned, but she'd gotten a real job offer."

    old "For the first time, she dared to think she might be alright."
    new "For the first time, she dared to think she might be alright."

    old "Laying down her head, she was soon fast asleep."
    new "Laying down her head, she was soon fast asleep."

    old "When Sarah woke the next morning, her conversation with Ramsey was first on her mind."
    new "When Sarah woke the next morning, her conversation with Ramsey was first on her mind."

    old "A job at this Inn might just be the thing she needed."
    new "A job at this Inn might just be the thing she needed."

    old "Stability..."
    new "Stability..."

    old "And the Dunstin family seemed nice enough."
    new "And the Dunstin family seemed nice enough."

    old "Sarah had made up her mind."
    new "Sarah had made up her mind."

    old "Heading down stairs, she quickly found Ramsey, already hard at work."
    new "Heading down stairs, she quickly found Ramsey, already hard at work."

    old "Mornin."
    new "Mornin."

    old "He greeted her as he continued to work."
    new "He greeted her as he continued to work."

    old "I...mister Ramsey, sir..."
    new "I...mister Ramsey, sir..."

    old "He began to laugh loudly."
    new "He began to laugh loudly."

    old "Listen, Sarah, don't ever call me that again."
    new "Listen, Sarah, don't ever call me that again."

    old "You can just call me Ramsey, got it?"
    new "You can just call me Ramsey, got it?"

    old "Of course, sir- I mean, Ramsey...I just wanted to speak to you...about what we discussed yesterday."
    new "Of course, sir- I mean, Ramsey...I just wanted to speak to you...about what we discussed yesterday."

    old "Yesterday?"
    new "Yesterday?"

    old "The...job offer?"
    new "The...job offer?"

    old "Oh, of course! Sorry, little lady, I got so much goin on, sometimes I struggle to keep up with my own mind."
    new "Oh, of course! Sorry, little lady, I got so much goin on, sometimes I struggle to keep up with my own mind."

    old "Did you make a decision?"
    new "Did you make a decision?"

    old "I would very much like to take you up on it."
    new "I would very much like to take you up on it."

    old "Ramsey clasped his hands together."
    new "Ramsey clasped his hands together."

    old "That's great news!"
    new "That's great news!"

    old "A wide smile on his face seemed to suggest he was earnest."
    new "A wide smile on his face seemed to suggest he was earnest."

    old "Tell you what though, I'm a bit busy opening up here."
    new "Tell you what though, I'm a bit busy opening up here."

    old "How bout you grab a hold of my boy, Jacob. He can help you get started up."
    new "How bout you grab a hold of my boy, Jacob. He can help you get started up."

    old "I will. Thank you for the opportunity!"
    new "I will. Thank you for the opportunity!"

    old "Sarah watched as Ramsey took off, heading down into the cellars as he carried two large kegs with no trouble at all."
    new "Sarah watched as Ramsey took off, heading down into the cellars as he carried two large kegs with no trouble at all."

    old "As she walked through the Inn, she saw that the first few customers were already seated and being served."
    new "As she walked through the Inn, she saw that the first few customers were already seated and being served."

    old "Working here would probably mean waking up a lot earlier than she was used to."
    new "Working here would probably mean waking up a lot earlier than she was used to."

    old "Sarah scanned the room, searching for Jacob."
    new "Sarah scanned the room, searching for Jacob."

    old "It took her a minute until she finally spotted him walking quickly through the room, carrying a crate full of fresh produce from the market."
    new "It took her a minute until she finally spotted him walking quickly through the room, carrying a crate full of fresh produce from the market."

    old "She saw him continue to walk."
    new "She saw him continue to walk."

    old "Hey, Jacob!"
    new "Hey, Jacob!"

    old "The boy stopped and turned at hearing his name."
    new "The boy stopped and turned at hearing his name."

    old "When his eyes fell on her, he looked more confused than anything."
    new "When his eyes fell on her, he looked more confused than anything."

    old "Sarah quickly made her way towards him."
    new "Sarah quickly made her way towards him."

    old "I...is there anything you want?"
    new "I...is there anything you want?"

    old "Sarah kept up her smile, desite how curt he was with her."
    new "Sarah kept up her smile, desite how curt he was with her."

    old "Clearly, the boy had not inherited the happy-go-lucky attitude of his father."
    new "Clearly, the boy had not inherited the happy-go-lucky attitude of his father."

    old "I spoke with your dad."
    new "I spoke with your dad."

    old "He offered me a job here."
    new "He offered me a job here."

    old "She saw Jacob roll his eyes."
    new "She saw Jacob roll his eyes."

    old "Of course he did."
    new "Of course he did."

    old "And he said that I should ask you for help on getting started."
    new "And he said that I should ask you for help on getting started."

    old "Jacob held up the crate."
    new "Jacob held up the crate."

    old "Well, I'm busy right now."
    new "Well, I'm busy right now."

    old "And really, I have a full day of things to do, so just..."
    new "And really, I have a full day of things to do, so just..."

    old "He gestured at a seat."
    new "He gestured at a seat."

    old "Just wait and maybe I'll come by later today."
    new "Just wait and maybe I'll come by later today."

    old "But no promise, I'm really busy."
    new "But no promise, I'm really busy."

    old "And with with that, Sarah watched Jacob take off."
    new "And with with that, Sarah watched Jacob take off."

    old "She thought of calling after him, saying something, but he was already gone."
    new "She thought of calling after him, saying something, but he was already gone."

    old "Deflated, Sarah sat down on a nearby bench."
    new "Deflated, Sarah sat down on a nearby bench."

    old "Jacob had said he'd come back later. Maybe. Or maybe not at all."
    new "Jacob had said he'd come back later. Maybe. Or maybe not at all."

    old "Don't mind him."
    new "Don't mind him."

    old "Sarah looked up at the sudden voice."
    new "Sarah looked up at the sudden voice."

    old "My brother, Jacob. He can be an asshole sometimes."
    new "My brother, Jacob. He can be an asshole sometimes."

    old "He doesn't mean to be, but...well..."
    new "He doesn't mean to be, but...well..."

    old "Sarah softly shook her head."
    new "Sarah softly shook her head."

    old "No, I don't think he was being mean...he said he was busy."
    new "No, I don't think he was being mean...he said he was busy."

    old "The girl smiled as she sat down next to Sarah."
    new "The girl smiled as she sat down next to Sarah."

    old "He's always busy."
    new "He's always busy."

    old "And he always thinks he has to everything himself."
    new "And he always thinks he has to everything himself."

    old "Sarah saw the woman's eyes go up and down her body."
    new "Sarah saw the woman's eyes go up and down her body."

    old "I like your dress."
    new "I like your dress."

    old "Oh...thank you."
    new "Oh...thank you."

    old "It's very...foreign, I think. Looks expensive."
    new "It's very...foreign, I think. Looks expensive."

    old "You're not from around here?"
    new "You're not from around here?"

    old "I came from Rosanna, by way of Lethram"
    new "I came from Rosanna, by way of Lethram"

    old "Ooh wow, yeah that is far away."
    new "Ooh wow, yeah that is far away."

    old "Good thing you made it here though."
    new "Good thing you made it here though."

    old "I heard all the stories of what's happening overseas, with those barbarians...yikes."
    new "I heard all the stories of what's happening overseas, with those barbarians...yikes."

    old "Sarah just nodded, the sharp pain of being reminded of what was happening in her home country, stining."
    new "Sarah just nodded, the sharp pain of being reminded of what was happening in her home country, stining."

    old "My name's Elsa, by the way."
    new "My name's Elsa, by the way."

    old "Yeah, I heard your name before from your father. And I saw you when I got here yesterday."
    new "Yeah, I heard your name before from your father. And I saw you when I got here yesterday."

    old "Elsa smiled."
    new "Elsa smiled."

    old "Ah, I must have missed you. Or maybe I was too busy. We had a lot of people over yesterday."
    new "Ah, I must have missed you. Or maybe I was too busy. We had a lot of people over yesterday."

    old "A lot of people most days, actually."
    new "A lot of people most days, actually."

    old "Yeah, that's why Ramsey...uh, your father...he offered me a job..."
    new "Yeah, that's why Ramsey...uh, your father...he offered me a job..."

    old "Elsa's face lit up."
    new "Elsa's face lit up."

    old "A job! That's awesome!"
    new "A job! That's awesome!"

    old "It's...really? You're brother didn't seem that excited about it."
    new "It's...really? You're brother didn't seem that excited about it."

    old "Elsa shrugged."
    new "Elsa shrugged."

    old "Just ignore him. Like I said, he can be an asshole, but you'll learn his, uhm...oddities, I guess."
    new "Just ignore him. Like I said, he can be an asshole, but you'll learn his, uhm...oddities, I guess."

    old "We should be happy to have an extra pair of hands!"
    new "We should be happy to have an extra pair of hands!"

    old "Sarah smiled, suddenly feeling good again about having accepted the job."
    new "Sarah smiled, suddenly feeling good again about having accepted the job."

    old "Yeah, your dad told me to speak to Jacob about getting started, but he...well, you heard him."
    new "Yeah, your dad told me to speak to Jacob about getting started, but he...well, you heard him."

    old "Elsa nodded."
    new "Elsa nodded."

    old "Sure. How about, instead, I help you get started?"
    new "Sure. How about, instead, I help you get started?"

    old "I'd love that!"
    new "I'd love that!"

    old "Great! Just follow me to the bar."
    new "Great! Just follow me to the bar."

    old "Elsa got up and motioned for Sarah to follow. She quickly did."
    new "Elsa got up and motioned for Sarah to follow. She quickly did."

    old "Behind the bar, Elsa laid out a scroll."
    new "Behind the bar, Elsa laid out a scroll."

    old "These here are the menu items."
    new "These here are the menu items."

    old "She ran her finger down the list."
    new "She ran her finger down the list."

    old "You can read, I assume?"
    new "You can read, I assume?"

    old "Her eyes tracked the items. Sandwhiches. Stew. Grilled pork."
    new "Her eyes tracked the items. Sandwhiches. Stew. Grilled pork."

    old "Just memorize the menu, and then you can start by taking on orders."
    new "Just memorize the menu, and then you can start by taking on orders."

    old "Write up an order list, file it up on the counter there, and my dad will cook them in order."
    new "Write up an order list, file it up on the counter there, and my dad will cook them in order."

    old "Then you just take the orders back to the table."
    new "Then you just take the orders back to the table."

    old "Easy as can be, right?"
    new "Easy as can be, right?"

    old "It sounded easy enough."
    new "It sounded easy enough."

    old "Great. My theory is that you learn by doing, so just get out on the floor and start taking some orders."
    new "Great. My theory is that you learn by doing, so just get out on the floor and start taking some orders."

    old "I'll take this side of the room, you take the other."
    new "I'll take this side of the room, you take the other."

    old "Okay!"
    new "Okay!"

    old "Full of energy, Sarah strode out onto the floor."
    new "Full of energy, Sarah strode out onto the floor."

    old "Just about half the tables had customers waiting."
    new "Just about half the tables had customers waiting."

