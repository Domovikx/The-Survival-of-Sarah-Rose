    new "The only place we can be sure we won't be found."

    old "Sarah slowly nodded."
    new "Sarah slowly nodded."

    old "I...understand."
    new "I...understand."

    old "She looked directly at Alaric."
    new "She looked directly at Alaric."

    old "Let's go."
    new "Let's go."

    old "Sarah nodded, resolute."
    new "Sarah nodded, resolute."

    old "If the Guard gets us, we're fucked...at least in there we got a chance, right?"
    new "If the Guard gets us, we're fucked...at least in there we got a chance, right?"

    old "Good."
    new "Good."

